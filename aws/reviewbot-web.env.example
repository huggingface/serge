# This file is copied to /etc/reviewbot/reviewbot-web.env by deploy.sh.
# If GITHUB_PRIVATE_KEY_PATH points to a local PEM, deploy.sh uploads that file
# to /etc/reviewbot/github-app.pem and rewrites the env file automatically.

# --- GitHub App (used to publish reviews) ---
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=/path/to/pem
# Required when the same reviewbot-web deployment receives GitHub App
# comment webhooks at https://serge.huggingface.tech/webhook.
GITHUB_WEBHOOK_SECRET=replace-me

# --- LLM ---
LLM_STREAM=1
LLM_API_BASE=https://router.huggingface.co/v1
LLM_BILL_TO=your-org
LLM_MODEL=moonshotai/Kimi-K2.6
LLM_API_KEY=sk-...
# Optional per-provider keys for the web UI provider picker. HF can use
# LLM_API_KEY; OpenAI/Anthropic/Custom need their own key unless that
# provider is the default LLM_API_BASE above.
# HF_API_KEY=hf_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# CUSTOM_LLM_API_KEY=...
# LLM_MAX_TOKENS=4096
# Hard cap on cumulative *input* tokens consumed by LLM calls across a
# single review (all chunks + tool turns). When exceeded the agentic
# loop stops, the model is asked for a final review with tools off,
# and any remaining diff chunks are skipped. Default 2_000_000; set
# to 0 to disable.
# LLM_MAX_INPUT_TOKENS=2000000
# Controls how much "thinking" reasoning models (Kimi-K2, o-series)
# expend per turn. Lower = faster + cheaper, at the cost of analysis
# depth. Leave unset to use the model's default. Common: low|medium|high.
# LLM_REASONING_EFFORT=medium

# --- Web auth ---
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxx
GITHUB_OAUTH_CLIENT_SECRET=change-me
# nginx on the box terminates HTTPS, so this is https on the public hostname.
GITHUB_OAUTH_CALLBACK_URL=https://serge.huggingface.tech/auth/callback
# Generate a strong secret with: openssl rand -hex 32
# Required (no fallback) when DEV_NO_AUTH is off. deploy.sh will mint one
# automatically if you leave this as `replace-me`.
WEB_SESSION_SECRET=replace-me
# DEV_NO_AUTH=1 disables OAuth and access control entirely. Off in
# production deployments.
DEV_NO_AUTH=0
# WEB_INSECURE_COOKIES=1 drops the Secure flag from the session cookie
# so plain-HTTP deployments work (e.g. VPN-private hosts without TLS).
# Leave unset/0 here: nginx on the box terminates HTTPS, so the browser
# talks TLS and the Secure cookie flag is correct (the nginx->app hop is
# loopback plain HTTP, which is fine).
# WEB_INSECURE_COOKIES=0
# Required when DEV_NO_AUTH=0 (at least one of):
# WEB_ALLOWED_USERS=octocat
# WEB_ALLOWED_ORG=acme

# --- Security ---
# Isolation policy for PR-touching subprocesses (helper tools and the
# .ai/context-script). "require" refuses to run them unless bubblewrap is
# installed (deploy.sh installs it) — keep this on in production so a
# fork PR can never run code on the host outside the sandbox. "auto"
# sandboxes when bwrap is present else runs unwrapped (local dev); "off"
# disables sandboxing. See docs/security-architecture.md.
HELPER_SANDBOX=require

# --- App behavior ---
MENTION_TRIGGER=@askserge
REVIEW_EVENT=COMMENT
MAX_DIFF_CHARS=200000
REVIEW_RULES_PATH=.ai/review-rules.md
DEFAULT_REVIEW_RULES=Apply general Python correctness and security standards.
LOG_LEVEL=INFO

# Optional:
# ALLOW_APPROVE controls whether the publish endpoint will accept an
# APPROVE event. The LLM's choice of event is influenced by attacker-
# controlled PR content, so leave this off unless you trust the reviewer
# operators to verify every APPROVE before clicking publish.
# ALLOW_APPROVE=false
# PERSONA_HEADER=**Serge** says:
# CONTEXT_SCRIPT_PATH=.ai/context-script
# CONTEXT_SCRIPT_TIMEOUT=30
# REPO_CHECKOUT_PATH=
# Cap on "blind" tool-only turns (the model called tools without
# reasoning or content). Productive turns are free. Default 30; set
# higher for very tool-heavy reviews, or to 0 to disable the cap.
# TOOL_MAX_ITERATIONS=30
# Path to the SQLite file used to persist review jobs (metadata, draft,
# event history). Default is relative to the service WorkingDirectory
# (/opt/app/jobs.db on the deploy host); switch to /var/lib/reviewbot/
# if you'd rather keep state off the app dir.
# WEB_STORE_PATH=/opt/app/jobs.db
# Global cap on retained jobs; older finished jobs are pruned on each
# new submission. Running jobs are never pruned.
# WEB_JOB_RETENTION=25
